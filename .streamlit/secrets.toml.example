# Copy this file to .streamlit/secrets.toml and fill in your email provider.
# For Gmail, use an App Password rather than your normal account password.

SMTP_HOST = "smtp.gmail.com"
SMTP_PORT = 587
SMTP_USER = "sales@example.com"
SMTP_PASSWORD = "replace-with-app-password"
FROM_EMAIL = "sales@example.com"

# Required before publishing the website.
# Option A: one shared employee login.
EMPLOYEE_PASSWORD = "replace-with-a-strong-employee-password"

# Change this before sharing the website with other people.
ADMIN_PASSWORD = "replace-with-a-strong-password"

# Option B: individual employee logins. If this section is present,
# each employee can sign in with their own username and password.
[EMPLOYEE_USERS]
sales = "replace-with-sales-password"
warehouse = "replace-with-warehouse-password"
manager = "replace-with-manager-password"
